# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/chatflow

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chatflow
MINIO_USE_SSL=false
# Public base URL used to build file URLs returned to clients.
# If empty, falls back to http://{MINIO_ENDPOINT}:{MINIO_PORT}/{MINIO_BUCKET}/...
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── WebHook ─────────────────────────────────────────────────────────────────
# Base URL this server is reachable at (used to register WPP-Connect webhooks).
WEBHOOK_BASE_URL=http://localhost:3000
